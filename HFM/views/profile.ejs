<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate - My Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-dashboard.css">
    <link rel="stylesheet" href="/stylesheets/profile.css">
</head>
<body>

<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">
        Home Food Marketplace
    </a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <a href="/login" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">
            Log Out
        </a>
    </div>
</nav>

<div class="dashboard-layout">
    <div class="sidebar-container" style="display:flex;flex-direction:column;">
        <nav class="sidebar-nav">
            <a href="<%= dashboardUrl %>" class="sidebar-nav-link" id="sidebar-home">
                <i class="bi bi-house-fill"></i>
                <span>Home</span>
            </a>
            <% if (user.role === 'customer') { %>
            <a href="<%= browseUrl %>" class="sidebar-nav-link" id="sidebar-browse">
                <i class="bi bi-search"></i>
                <span>Browse</span>
            </a>
            <% } %>
        </nav>
        <div class="sidebar-profile-foot">
            <a href="/profile" class="sidebar-nav-link active" id="sidebar-profile" style="background:rgba(255,255,255,.2);">
                <i class="bi bi-person-circle"></i>
                <span>Profile</span>
            </a>
        </div>
    </div>

    <main class="main-content">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="profile-avatar" id="avatar-initials">--</div>
            <div>
                <h1 id="header-name" style="font-family:'Poppins',sans-serif;font-size:1.5rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                    My Profile
                </h1>
                <span style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#999;">
                    <%= user.role === 'cook' ? 'Merchant account' : 'Customer account' %>
                </span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="profile-card mb-4">
                    <div class="profile-section-title">
                        <i class="bi bi-person"></i> Personal Information
                    </div>

                    <div class="alert alert-danger py-2" id="profile-error" style="display:none;"></div>

                    <div class="row g-3" id="view-mode">
                        <div class="col-6">
                            <div class="profile-field">
                                <div class="profile-field-label">First Name</div>
                                <div class="profile-field-value" id="vw-first"></div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="profile-field">
                                <div class="profile-field-label">Last Name</div>
                                <div class="profile-field-value" id="vw-last"></div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="profile-field">
                                <div class="profile-field-label">Email Address</div>
                                <div class="profile-field-value" id="vw-email"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="profile-field">
                                <div class="profile-field-label">Phone Number</div>
                                <div class="profile-field-value" id="vw-phone"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="profile-field">
                                <div class="profile-field-label">Date of Birth</div>
                                <div class="profile-field-value" id="vw-dob"></div>
                            </div>
                        </div>
                        <div class="col-12 mt-1">
                            <button class="btn-hp-outline-edit" id="btn-edit" onclick="enterEditMode()">
                                <i class="bi bi-pencil me-1"></i>Edit Profile
                            </button>
                        </div>
                    </div>

                    <div id="edit-mode" style="display:none;">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-first">First Name</label>
                                <input type="text" id="ed-first" class="form-control profile-input">
                            </div>
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-last">Last Name</label>
                                <input type="text" id="ed-last" class="form-control profile-input">
                            </div>
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-phone">Phone Number</label>
                                <input type="tel" id="ed-phone" class="form-control profile-input">
                            </div>
                            <div class="col-md-6">
                                <label class="profile-field-label mb-1" for="ed-dob">Date of Birth</label>
                                <input type="date" id="ed-dob" class="form-control profile-input">
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button class="btn-hp-edit" onclick="saveChanges()">
                                <i class="bi bi-check2 me-1"></i>Save Changes
                            </button>
                            <button class="btn-hp-outline-edit" onclick="cancelEdit()">Cancel</button>
                        </div>
                    </div>
                </div>

                <div class="profile-card">
                    <div class="profile-section-title">
                        <i class="bi bi-geo-alt"></i> Default Address
                    </div>

                    <div id="view-addr">
                        <div class="profile-field">
                            <div class="profile-field-label">Street</div>
                            <div class="profile-field-value" id="vw-street"></div>
                        </div>
                        <div class="profile-field mt-2">
                            <div class="profile-field-label">Suite / Apt</div>
                            <div class="profile-field-value" id="vw-suite"></div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-md-5">
                                <div class="profile-field">
                                    <div class="profile-field-label">City</div>
                                    <div class="profile-field-value" id="vw-city"></div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="profile-field">
                                    <div class="profile-field-label">State</div>
                                    <div class="profile-field-value" id="vw-state"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="profile-field">
                                    <div class="profile-field-label">ZIP</div>
                                    <div class="profile-field-value" id="vw-zip"></div>
                                </div>
                            </div>
                        </div>
                        <button class="btn-hp-outline-edit mt-3" onclick="toggleAddrEdit(true)">
                            <i class="bi bi-pencil me-1"></i>Edit Address
                        </button>
                    </div>

                    <div id="edit-addr" style="display:none;">
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="ed-street">Street Address</label>
                            <input type="text" id="ed-street" class="form-control profile-input">
                        </div>
                        <div class="mb-3">
                            <label class="profile-field-label mb-1" for="ed-suite">Suite / Apt</label>
                            <input type="text" id="ed-suite" class="form-control profile-input" placeholder="e.g. Apt 7, Suite 300">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="profile-field-label mb-1" for="ed-city">City</label>
                                <input type="text" id="ed-city" class="form-control profile-input">
                            </div>
                            <div class="col-md-3">
                                <label class="profile-field-label mb-1" for="ed-state">State</label>
                                <input type="text" id="ed-state" class="form-control profile-input" maxlength="2">
                            </div>
                            <div class="col-md-4">
                                <label class="profile-field-label mb-1" for="ed-zip">ZIP</label>
                                <input type="text" id="ed-zip" class="form-control profile-input" maxlength="10">
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn-hp-edit" onclick="saveAddr()">
                                <i class="bi bi-check2 me-1"></i>Save Address
                            </button>
                            <button class="btn-hp-outline-edit" onclick="toggleAddrEdit(false)">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="toast-save" id="save-toast">
    <i class="bi bi-check-circle-fill me-2" style="color:#7a9b6e;"></i>Changes saved successfully.
</div>

<script>
window.__PROFILE_DATA__ = <%- JSON.stringify(profileData) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/profile.js"></script>
</body>
</html>
