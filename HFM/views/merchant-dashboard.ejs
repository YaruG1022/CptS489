<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate — Merchant Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-dashboard.css">
</head>
<body>

<!-- Navigation Bar -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/merchant-dashboard" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">
        HomePlate
    </a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/profile" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-person-circle me-1"></i>Profile
        </a>
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <a href="/logout" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">
            Log Out
        </a>
    </div>
</nav>

<!-- Dashboard Body -->
<div class="dashboard-layout">

    <!-- Sidebar -->
    <div class="sidebar-container" style="display:flex;flex-direction:column;">
        <nav class="sidebar-nav">
            <a href="/merchant-dashboard" class="sidebar-nav-link" id="sidebar-home">
                <i class="bi bi-house-fill"></i>
                <span>Home</span>
            </a>
        </nav>
        <div style="margin-top:auto;padding-bottom:12px;">
            <a href="/profile" class="sidebar-nav-link" id="sidebar-profile">
                <i class="bi bi-person-circle"></i>
                <span>Profile</span>
            </a>
        </div>
    </div>

    <!-- Main content -->
    <main class="main-content">

<% if (!restaurant) { %>
        <!-- ========== RESTAURANT PICKER ========== -->
        <div class="mb-4">
            <h1 style="font-family:'Poppins',sans-serif;font-size:1.6rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                Select a Restaurant
            </h1>
            <p style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:#888;margin:4px 0 0;">
                Choose an existing restaurant or create a new one.
            </p>
        </div>

        <% if (restaurants.length > 0) { %>
        <div class="row g-3 mb-4">
            <% restaurants.forEach(function(r) { %>
            <div class="col-12 col-md-6">
                <a href="/merchant-dashboard?r=<%= r.id %>" class="text-decoration-none">
                    <div class="section-card" style="cursor:pointer;transition:box-shadow .15s,transform .15s;">
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:48px;height:48px;border-radius:10px;background:rgba(197,90,58,.10);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-shop" style="font-size:22px;color:var(--burnt-orange-primary);"></i>
                            </div>
                            <div>
                                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:1rem;color:var(--charcoal-gray-secondary);"><%= r.name %></div>
                                <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;"><i class="bi bi-geo-alt me-1"></i><%= r.address %></div>
                                <% if (r.tags && r.tags.length > 0) { %>
                                <div style="margin-top:6px;display:flex;flex-wrap:wrap;gap:4px;">
                                    <% r.tags.forEach(function(tag) { %>
                                    <span class="badge" style="background:rgba(197,90,58,.12);color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-size:0.68rem;font-weight:500;text-transform:capitalize;padding:3px 8px;border:1px solid rgba(197,90,58,.25);"><%= tag %></span>
                                    <% }); %>
                                </div>
                                <% } %>
                            </div>
                            <i class="bi bi-chevron-right ms-auto" style="font-size:1.2rem;color:#ccc;"></i>
                        </div>
                    </div>
                </a>
            </div>
            <% }); %>
        </div>
        <% } %>

        <!-- Create new restaurant -->
        <div class="section-card">
            <h3 style="font-family:'Poppins',sans-serif;font-size:1.05rem;font-weight:600;color:var(--charcoal-gray-secondary);margin-bottom:16px;">
                <i class="bi bi-plus-circle me-2" style="color:var(--burnt-orange-primary);"></i>Create New Restaurant
            </h3>
            <form method="POST" action="/merchant-restaurant">
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Restaurant Name</label>
                    <input type="text" class="form-control" name="name" placeholder="e.g. Mom's Kitchen" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Address</label>
                    <input type="text" class="form-control" name="address" placeholder="e.g. 123 Main St, Pullman, WA 99163" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Tags <span style="color:#999;font-size:0.8rem;">(comma-separated)</span></label>
                    <input type="text" class="form-control" name="tags" placeholder="e.g. Indian, Korean, Fast Food, Vegetarian">
                </div>
                <button type="submit" class="btn btn-hp">
                    <i class="bi bi-plus-lg me-1"></i>Create Restaurant
                </button>
            </form>
        </div>

<% } else { %>
        <!-- ========== DASHBOARD (restaurant selected) ========== -->

        <!-- Page title with restaurant switcher -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <div>
                <h1 style="font-family:'Poppins',sans-serif;font-size:1.6rem;font-weight:700;color:var(--charcoal-gray-secondary);margin:0;">
                    <%= restaurant.name %>
                </h1>
                <p style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;margin:4px 0 0;">
                    <i class="bi bi-geo-alt me-1"></i><%= restaurant.address %>
                </p>
                <% if (restaurant.tags && restaurant.tags.length > 0) { %>
                <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;">
                    <% restaurant.tags.forEach(function(tag) { %>
                    <span class="badge" style="background:rgba(197,90,58,.12);color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-size:0.72rem;font-weight:500;text-transform:capitalize;padding:4px 9px;border:1px solid rgba(197,90,58,.25);"><%= tag %></span>
                    <% }); %>
                </div>
                <% } %>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a href="/merchant-dashboard?switch=1" class="btn btn-sm btn-hp-outline">
                    <i class="bi bi-arrow-left-right me-1"></i>Switch Restaurant
                </a>
                <form method="POST" action="/merchant-restaurant/delete" class="m-0"
                      onsubmit="return confirm('Delete this restaurant? This will permanently remove its menu items and order history.');">
                    <input type="hidden" name="restaurantId" value="<%= restaurant.id %>">
                    <button type="submit" class="btn btn-sm" style="border:1px solid #dc3545;color:#dc3545;background:#fff;font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 14px;">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>

        <!-- Stat cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-6">
                <div class="cust-stat-card" style="border-left:4px solid var(--sage-green-secondary);">
                    <div class="cust-stat-icon" style="background:rgba(122,155,110,.10);color:var(--sage-green-secondary);">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div>
                        <div class="stat-num" id="stat-completed"><%= completedCount %></div>
                        <div class="stat-label">Completed Orders</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-6">
                <div class="cust-stat-card" style="border-left:4px solid var(--golden-yellow-secondary);">
                    <div class="cust-stat-icon" style="background:rgba(232,180,74,.10);color:var(--golden-yellow-secondary);">
                        <i class="bi bi-book"></i>
                    </div>
                    <div>
                        <div class="stat-num" id="stat-menu"><%= menuCount %></div>
                        <div class="stat-label">Menu Items</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section tab nav -->
        <nav class="section-tab-nav mb-4">
            <a href="#" class="tab-btn active" id="tab-current-orders"
               onclick="showSection('current-orders'); return false;">
                <i class="bi bi-clock-history me-1"></i>Current Orders
            </a>
            <a href="#" class="tab-btn" id="tab-completed-orders"
               onclick="showSection('completed-orders'); return false;">
                <i class="bi bi-check-circle me-1"></i>Completed Orders
            </a>
            <a href="#" class="tab-btn" id="tab-my-menu"
               onclick="showSection('my-menu'); return false;">
                <i class="bi bi-book me-1"></i>My Menu
            </a>
        </nav>

        <!-- Dynamic section content -->
        <div id="section-content">
            <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
                <div class="spinner-border" style="color:var(--burnt-orange-primary);" role="status"></div>
                <div class="mt-2" style="font-size:0.88rem;">Loading...</div>
            </div>
        </div>
<% } %>

    </main>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<% if (restaurant) { %>
<script src="/javascripts/merchant-dashboard.js"></script>
<% } %>
</body>
</html>
