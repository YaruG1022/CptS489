<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate &mdash; Your Cart</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body>

<!-- ── Navigation Bar ─────────────────────────── -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/browse" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">HomePlate</a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <a href="customer-dashboard.html" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-grid me-1"></i>Dashboard
        </a>
        <% if (user) { %>
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <% } %>
        <a href="/index.html" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">Log Out</a>
    </div>
</nav>

<!-- ── Main Content ──────────────────────────── -->
<div class="browse-page">

    <a href="/browse" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;display:inline-block;margin-bottom:20px;">
        <i class="bi bi-arrow-left me-1"></i>Back to Browse
    </a>

    <div class="mb-4">
        <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:var(--charcoal-gray-secondary);margin:0 0 4px;">
            Your Cart
        </h1>
    </div>

    <% if (cartGroups.length === 0) { %>
    <!-- Empty cart -->
    <div class="text-center py-5" style="color:#aaa;font-family:'Poppins',sans-serif;">
        <i class="bi bi-bag" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
        <div style="font-size:1rem;font-weight:500;">Your cart is empty</div>
        <div style="font-size:0.85rem;margin-top:6px;">
            <a href="/browse" style="color:var(--burnt-orange-primary);">Browse restaurants</a> to find something delicious!
        </div>
    </div>
    <% } else { %>

    <% cartGroups.forEach(function(group) { %>
    <div class="mb-4" id="order-group-<%= group.order.id %>">
        <!-- Restaurant header -->
        <div style="font-family:'Poppins',sans-serif;font-size:0.92rem;font-weight:600;color:var(--charcoal-gray-secondary);margin-bottom:10px;">
            <i class="bi bi-house-heart me-1" style="color:var(--burnt-orange-primary);"></i>
            <%= group.restaurant ? group.restaurant.name : 'Restaurant' %>
        </div>

        <div style="background:#fff;border-radius:12px;padding:22px 24px;box-shadow:0 2px 8px rgba(0,0,0,0.07);">

            <% group.items.forEach(function(item, idx) { %>
            <div class="cart-page-item" id="cart-item-<%= item.id %>" data-price="<%= item.price %>"
                 <% if (idx === group.items.length - 1) { %>style="border-bottom:none;"<% } %>>
                <div class="cart-page-item-img" style="background:#f5ede0;"></div>
                <div class="flex-grow-1">
                    <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.92rem;color:var(--charcoal-gray-secondary);">
                        <%= item.name %>
                    </div>
                    <div style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#888;margin-top:2px;">
                        $<%= parseFloat(item.price).toFixed(2) %> each
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="qty-controls">
                        <button class="qty-btn" onclick="updateQty(<%= item.id %>, -1)">&minus;</button>
                        <span class="qty-num" id="qty-<%= item.id %>"><%= item.quantity %></span>
                        <button class="qty-btn" onclick="updateQty(<%= item.id %>, 1)">+</button>
                    </div>
                    <div style="font-family:'Poppins',sans-serif;font-weight:700;font-size:0.92rem;color:var(--burnt-orange-primary);min-width:52px;text-align:right;"
                         id="price-<%= item.id %>">
                        $<%= (parseFloat(item.price) * item.quantity).toFixed(2) %>
                    </div>
                    <button class="btn btn-sm" style="color:#ccc;border:none;background:none;padding:4px 6px;"
                            title="Remove" onclick="removeItem(<%= item.id %>)">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>
            </div>
            <% }); %>

            <!-- Add More + Checkout -->
            <div class="mt-3 pt-3 d-flex align-items-center justify-content-between" style="border-top:1px dashed #e4e4e4;">
                <a href="/restaurant-detail?id=<%= group.restaurant ? group.restaurant.id : '' %>"
                   style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:600;color:var(--burnt-orange-primary);text-decoration:none;">
                    <i class="bi bi-plus-circle me-1"></i>Add more items
                </a>
                <a href="checkout.html" class="btn btn-hp" style="padding:8px 24px;font-size:0.88rem;">
                    <i class="bi bi-lock me-1"></i>Proceed to Checkout
                </a>
            </div>

        </div>
    </div>
    <% }); %>

    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/cart.js"></script>
</body>
</html>
