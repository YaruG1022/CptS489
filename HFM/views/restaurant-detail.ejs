<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate &mdash; <%= restaurant.name %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body>

<!-- ── Navigation Bar ─────────────────────────── -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">Home Food Marketplace</a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/browse" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-search me-1"></i>Browse
        </a>
        <a href="/customer-dashboard" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-grid me-1"></i>Dashboard
        </a>
        <a href="/cart" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-bag me-1"></i>Cart
            <span id="cart-badge" class="badge ms-1" style="background:var(--golden-yellow-secondary);color:var(--charcoal-gray-secondary);font-size:0.65rem;"><%= cartCount %></span>
        </a>
        <% if (user) { %>
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <% } %>
        <a href="/logout" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">Log Out</a>
    </div>
</nav>

<!-- ── Back breadcrumb ────────────────────────── -->
<div style="background:var(--cream-primary);padding:10px 32px;border-bottom:1px solid #eadfc8;">
    <a href="/browse" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;">
        <i class="bi bi-arrow-left me-1"></i>Back to Browse
    </a>
</div>

<!-- ── Restaurant Profile Banner ─────────────── -->
<div class="restaurant-profile-banner">
    <div style="max-width:1200px;margin:0 auto;">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <!-- Cook avatar -->
            <div style="width:80px;height:80px;border-radius:16px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-weight:700;font-size:2.2rem;color:#fff;flex-shrink:0;">
                <%= owner && owner.firstName ? owner.firstName.charAt(0).toUpperCase() : 'C' %>
            </div>
            <!-- Info -->
            <div class="flex-grow-1">
                <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.5rem;color:#fff;margin:0 0 4px;">
                    <%= restaurant.name %>
                </h1>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.88rem;color:rgba(255,255,255,.8);margin-bottom:10px;">
                    <% if (owner && owner.cuisine) { %><%= owner.cuisine %> &middot; <% } %>
                    By <%= owner ? (owner.firstName + ' ' + owner.lastName) : 'Unknown' %>
                </div>
                <div class="d-flex flex-wrap gap-3" style="font-family:'Open Sans',sans-serif;font-size:0.83rem;color:rgba(255,255,255,.85);">
                    <% if (owner && owner.deliveryFee != null) { %>
                    <span><i class="bi bi-truck me-1"></i>$<%= parseFloat(owner.deliveryFee).toFixed(2) %> delivery fee</span>
                    <% } %>
                    <% if (owner && owner.minimumOrder != null && parseFloat(owner.minimumOrder) > 0) { %>
                    <span><i class="bi bi-bag me-1"></i>$<%= parseFloat(owner.minimumOrder).toFixed(2) %> minimum</span>
                    <% } %>
                    <span><i class="bi bi-geo-alt me-1"></i><%= restaurant.address %></span>
                </div>
            </div>
        </div>

        <% if (owner && owner.bio) { %>
        <p style="font-family:'Open Sans',sans-serif;font-size:0.86rem;color:rgba(255,255,255,.75);margin:16px 0 0;max-width:700px;line-height:1.6;">
            <%= owner.bio %>
        </p>
        <% } %>
    </div>
</div>

<!-- ── Main Content ──────────────────────────── -->
<div style="max-width:1200px;margin:0 auto;padding:28px 24px;">
    <div class="row g-4">
        <div class="col-12">

            <% var catKeys = Object.keys(categories); %>
            <% if (catKeys.length === 0) { %>
            <div class="text-center py-5" style="color:#aaa;font-family:'Poppins',sans-serif;">
                <i class="bi bi-book" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
                <div style="font-size:1rem;font-weight:500;">No menu items available yet</div>
                <div style="font-size:0.85rem;margin-top:6px;">Check back soon!</div>
            </div>
            <% } else { %>
            <% var colorIdx = 0; %>
            <% catKeys.forEach(function(catName) { %>
            <div class="mb-4">
                <h5 style="font-family:'Poppins',sans-serif;font-weight:700;color:var(--charcoal-gray-secondary);margin-bottom:14px;">
                    <i class="bi bi-bookmark me-1"></i><%= catName %>
                </h5>
                <% categories[catName].forEach(function(item) { %>
                <div class="menu-item-card">
                    <div class="menu-item-img" style="background:<%= bgColors[colorIdx++ % bgColors.length] %>;"></div>
                    <div class="menu-item-info">
                        <div class="menu-item-name"><%= item.name %></div>
                        <% if (item.description) { %>
                        <div class="menu-item-desc"><%= item.description %></div>
                        <% } %>
                        <div class="menu-item-price">$<%= parseFloat(item.price).toFixed(2) %></div>
                    </div>
                    <button class="menu-item-add" onclick="addToCart(this, <%= item.id %>, <%= restaurant.id %>)">
                        <i class="bi bi-plus me-1"></i>Add
                    </button>
                </div>
                <% }); %>
            </div>
            <% }); %>
            <% } %>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/javascripts/restaurant-detail.js"></script>
</body>
</html>
