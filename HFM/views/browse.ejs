<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate - Browse Cooks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body>

<!-- Navigation Bar -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/browse" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">HomePlate</a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/customer-dashboard" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-grid me-1"></i>Dashboard
        </a>
        <a href="/cart" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-bag me-1"></i>Cart
            <span class="badge ms-1" style="background:var(--golden-yellow-secondary);color:var(--charcoal-gray-secondary);font-size:0.65rem;">0</span>
        </a>
        <% if (user) { %>
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <% } %>
        <a href="/logout" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">Log Out</a>
    </div>
</nav>

<!-- Hero Search -->
<div class="browse-hero">
    <h2>What are you craving today?</h2>
    <p>Discover homemade meals from talented cooks right in your neighborhood.</p>
    <form action="/browse" method="get">
        <div class="browse-search-bar">
            <i class="bi bi-search" style="color:#aaa;font-size:18px;flex-shrink:0;"></i>
            <input type="text" name="q" value="<%= query || '' %>" placeholder="Search for restaurants or addresses">
            <button type="submit" class="search-btn">Search</button>
        </div>
    </form>
</div>

<!-- Main Content -->
<div class="browse-page">

    <div>
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <% if (query) { %>
            <h3 class="browse-section-title mb-0">
                <i class="bi bi-search me-1"></i>Showing <%= restaurants.length %> result<%= restaurants.length !== 1 ? 's' : '' %> for "<%= query %>"
            </h3>
            <a href="/browse" style="font-family:'Poppins',sans-serif;font-size:0.85rem;color:#888;text-decoration:none;">
                <i class="bi bi-x me-1"></i>Clear Search
            </a>
            <% } else { %>
            <h3 class="browse-section-title mb-0">
                <i class="bi bi-geo-alt me-1"></i>All Cooks Near You
            </h3>
            <span style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                <%= restaurants.length %> cook<%= restaurants.length !== 1 ? 's' : '' %> found
            </span>
            <% } %>
        </div>

        <% if (restaurants.length === 0) { %>
        <div class="text-center py-5" style="color:#aaa;font-family:'Poppins',sans-serif;">
            <i class="bi bi-shop" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
            <% if (query) { %>
            <div style="font-size:1rem;font-weight:500;">No restaurants found for "<%= query %>"</div>
            <div style="font-size:0.85rem;margin-top:6px;">Try a different search term or <a href="/browse" style="color:var(--burnt-orange-primary);">browse all</a>.</div>
            <% } else { %>
            <div style="font-size:1rem;font-weight:500;">No restaurants available yet</div>
            <div style="font-size:0.85rem;margin-top:6px;">Check back soon for new cooks in your area!</div>
            <% } %>
        </div>
        <% } else { %>

        <div class="row g-3">
            <% restaurants.forEach(function(r) { %>
            <div class="col-6 col-md-4 col-lg-3">
                <a href="/restaurant-detail?id=<%= r.id %>" class="restaurant-card">
                    <div class="restaurant-card-img" style="background:<%= r.bgColor %>;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-shop" style="font-size:40px;color:var(--burnt-orange-primary);opacity:0.3;"></i>
                    </div>
                    <div class="restaurant-card-body">
                        <div class="restaurant-card-name"><%= r.name %></div>
                        <div class="restaurant-card-meta">
                            <i class="bi bi-geo-alt me-1"></i><%= r.address %>
                        </div>
                        <div class="restaurant-card-footer">
                            <span><i class="bi bi-book me-1"></i><%= r.menuCount %> item<%= r.menuCount !== 1 ? 's' : '' %></span>
                            <span><i class="bi bi-person-circle me-1"></i><%= r.ownerName %></span>
                        </div>
                    </div>
                </a>
            </div>
            <% }); %>
        </div>

        <% if (query) { %>
        <div class="text-center mt-4 pb-2" style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#aaa;">
            <i class="bi bi-check-circle me-1"></i>Showing all <%= restaurants.length %> result<%= restaurants.length !== 1 ? 's' : '' %> for "<%= query %>"
        </div>
        <% } %>

        <% } %>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
