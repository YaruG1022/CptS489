<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HomePlate &mdash; Order Confirmed!</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/customer-browse.css">
</head>
<body>

<!-- ── Navigation Bar ─────────────────────────── -->
<nav class="navbar navbar-expand-lg" style="background-color:var(--burnt-orange-primary);padding:0 1.5rem;">
    <a class="navbar-brand" href="/browse" style="font-family:'Pacifico',cursive;color:#fff;font-size:1.7rem;letter-spacing:.02em;">HomePlate</a>
    <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/browse" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-search me-1"></i>Browse
        </a>
        <a href="customer-dashboard.html" class="btn btn-sm"
           style="background:rgba(255,255,255,.15);color:#fff;font-family:'Poppins',sans-serif;font-size:0.85rem;border-radius:20px;padding:4px 14px;border:1px solid rgba(255,255,255,.3);">
            <i class="bi bi-grid me-1"></i>Dashboard
        </a>
        <% if (user) { %>
        <span style="font-family:'Poppins',sans-serif;font-size:0.9rem;color:rgba(255,255,255,.85);">
            Welcome, <%= user.firstName %>
        </span>
        <% } %>
        <a href="/index.html" class="btn btn-sm" style="background:#fff;color:var(--burnt-orange-primary);font-family:'Poppins',sans-serif;font-weight:600;border-radius:20px;padding:4px 16px;">Log Out</a>
    </div>
</nav>

<!-- ── Confirmation Card ──────────────────────── -->
<div class="browse-page">
    <div class="confirmation-card">

        <!-- Success icon -->
        <div class="confirmation-icon">
            <i class="bi bi-check-lg"></i>
        </div>

        <!-- Heading -->
        <h2 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:1.4rem;color:var(--charcoal-gray-secondary);margin-bottom:6px;">
            Order Confirmed!
        </h2>
        <p style="font-family:'Open Sans',sans-serif;font-size:0.9rem;color:#888;margin-bottom:24px;">
            Your order has been sent to <strong><%= restaurant.name %></strong>.<br>
            You'll receive a notification once the cook confirms.
        </p>

        <!-- Order details -->
        <div style="background:var(--cream-primary);border-radius:10px;padding:16px 20px;margin-bottom:24px;text-align:left;">

            <div class="confirmation-detail-row">
                <span style="color:#888;">Order Number</span>
                <strong style="font-family:'Poppins',sans-serif;">#HP-<%= order.id %></strong>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Restaurant</span>
                <span><%= restaurant.name %></span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Items</span>
                <span><%= items.map(function(i) { return i.name + (i.quantity > 1 ? ' \u00d7' + i.quantity : ''); }).join(', ') %></span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Total Paid</span>
                <strong style="font-family:'Poppins',sans-serif;color:var(--burnt-orange-primary);">$<%= parseFloat(order.total).toFixed(2) %></strong>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Payment</span>
                <span>Visa &middot;&middot;&middot;&middot; 4242</span>
            </div>
            <div class="confirmation-detail-row">
                <span style="color:#888;">Delivery Address</span>
                <span><%= order.deliveryStreet %>, <%= order.deliveryCity %>, <%= order.deliveryState %></span>
            </div>
        </div>

        <!-- ETA banner -->
        <div style="background:rgba(197,90,58,.06);border:1.5px solid rgba(197,90,58,.2);border-radius:10px;padding:14px 18px;margin-bottom:28px;display:flex;align-items:center;gap:14px;text-align:left;">
            <i class="bi bi-alarm" style="font-size:28px;color:var(--burnt-orange-primary);flex-shrink:0;"></i>
            <div>
                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;color:var(--charcoal-gray-secondary);">
                    Estimated Arrival: <span style="color:var(--burnt-orange-primary);">30 min</span>
                </div>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                    About 30 min after the cook starts preparing
                </div>
            </div>
        </div>

        <!-- CTA Buttons -->
        <div class="d-flex flex-column gap-2">
            <a href="customer-order-status.html" class="btn btn-hp" style="padding:12px;font-size:0.92rem;">
                <i class="bi bi-eye me-1"></i>View My Current Order
            </a>
            <a href="/browse" class="btn btn-hp-outline" style="padding:11px;font-size:0.88rem;">
                <i class="bi bi-search me-1"></i>Continue Browsing
            </a>
        </div>

        <p style="font-family:'Open Sans',sans-serif;font-size:0.78rem;color:#bbb;margin-top:20px;margin-bottom:0;">
            A confirmation has been sent to your registered email address.
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

