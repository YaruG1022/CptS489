<!-- merchant-my-menu.ejs — fragment rendered server-side via Sequelize + EJS -->

<div class="section-card">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h2 class="section-title mb-0"><i class="bi bi-book me-2"></i>My Menu</h2>
        <button class="btn btn-sm btn-hp" onclick="openAddModal()">
            <i class="bi bi-plus-lg me-1"></i>Add Item
        </button>
    </div>

    <div id="menu-items-list">
        <% if (items.length === 0) { %>
        <div class="text-center py-4" style="color:#aaa;font-family:'Poppins',sans-serif;font-size:0.9rem;">
            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
            No menu items yet. Click "Add Item" to get started.
        </div>
        <% } else { %>
        <% items.forEach(function(item) { %>
        <div class="menu-item-row" data-id="<%= item.id %>"
             data-name="<%= item.name %>"
             data-price="<%= item.price %>"
             data-quantity="<%= item.quantity || 0 %>"
             data-category="<%= item.category || '' %>"
             data-description="<%= item.description || '' %>">
            <div class="d-flex align-items-center gap-3 flex-grow-1" style="min-width:0;">
                <div class="menu-item-icon"><i class="bi bi-egg-fried"></i></div>
                <div style="flex:1;min-width:0;">
                    <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;"><%= item.name %></div>
                    <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;"><%= item.category || 'General' %></div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3" style="flex-shrink:0;">
                <span class="menu-qty-badge">Qty: <%= item.quantity || 0 %></span>
                <strong style="font-family:'Poppins',sans-serif;color:var(--burnt-orange-primary);min-width:60px;text-align:right;">$<%= parseFloat(item.price).toFixed(2) %></strong>
                <button class="btn btn-sm btn-hp-outline" onclick="openEditModal(<%= item.id %>)" title="Edit"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-hp-outline" style="color:#dc3545;border-color:#dc3545;" onclick="deleteMenuItem(<%= item.id %>)" title="Delete"><i class="bi bi-trash"></i></button>
            </div>
        </div>
        <% }); %>
        <% } %>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="menuItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;border:none;">
            <div class="modal-header" style="border-bottom:1px solid #f0e8d8;">
                <h5 class="modal-title" id="menuModalTitle" style="font-family:'Poppins',sans-serif;font-weight:600;">Add Menu Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Item Name</label>
                    <input type="text" class="form-control" id="modal-item-name" placeholder="e.g. Chicken Tikka Masala">
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Price ($)</label>
                        <input type="number" step="0.01" class="form-control" id="modal-item-price" placeholder="0.00">
                    </div>
                    <div class="col-6">
                        <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Quantity</label>
                        <input type="number" class="form-control" id="modal-item-qty" placeholder="0">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Category</label>
                    <input type="text" class="form-control" id="modal-item-category" placeholder="e.g. Indian · Curry">
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;">Description</label>
                    <textarea class="form-control" id="modal-item-desc" rows="2" placeholder="Short description..."></textarea>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f0e8d8;">
                <button type="button" class="btn btn-sm btn-hp-outline" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-hp" id="modal-save-btn" onclick="saveMenuItem()">Save</button>
            </div>
        </div>
    </div>
</div>

<script>
var editingId = null;

function openAddModal() {
    editingId = null;
    document.getElementById('menuModalTitle').textContent = 'Add Menu Item';
    document.getElementById('modal-item-name').value = '';
    document.getElementById('modal-item-price').value = '';
    document.getElementById('modal-item-qty').value = '';
    document.getElementById('modal-item-category').value = '';
    document.getElementById('modal-item-desc').value = '';
    new bootstrap.Modal(document.getElementById('menuItemModal')).show();
}

function openEditModal(id) {
    var row = document.querySelector('.menu-item-row[data-id="' + id + '"]');
    if (!row) return;
    editingId = id;
    document.getElementById('menuModalTitle').textContent = 'Edit Menu Item';
    document.getElementById('modal-item-name').value = row.dataset.name;
    document.getElementById('modal-item-price').value = row.dataset.price;
    document.getElementById('modal-item-qty').value = row.dataset.quantity;
    document.getElementById('modal-item-category').value = row.dataset.category;
    document.getElementById('modal-item-desc').value = row.dataset.description;
    new bootstrap.Modal(document.getElementById('menuItemModal')).show();
}

function saveMenuItem() {
    var name = document.getElementById('modal-item-name').value.trim();
    var price = document.getElementById('modal-item-price').value;
    var quantity = document.getElementById('modal-item-qty').value;
    var category = document.getElementById('modal-item-category').value.trim();
    var description = document.getElementById('modal-item-desc').value.trim();

    if (!name) { alert('Item name is required.'); return; }
    if (!price || parseFloat(price) < 0) { alert('Valid price is required.'); return; }

    var body = { name: name, price: price, quantity: quantity, category: category, description: description };
    var saveBtn = document.getElementById('modal-save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    var url = editingId ? '/api/menu/' + editingId : '/api/menu';
    var method = editingId ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    })
    .then(function (r) {
        if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Request failed'); });
        return r.json();
    })
    .then(function () {
        bootstrap.Modal.getInstance(document.getElementById('menuItemModal')).hide();
        showSection('my-menu');
    })
    .catch(function (err) {
        alert('Error: ' + err.message);
    })
    .finally(function () {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
    });
}

function deleteMenuItem(id) {
    if (!confirm('Are you sure you want to delete this item?')) return;

    var row = document.querySelector('.menu-item-row[data-id="' + id + '"]');
    if (row) { row.style.opacity = '0.5'; row.style.pointerEvents = 'none'; }

    fetch('/api/menu/' + id, { method: 'DELETE' })
        .then(function (r) {
            if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Delete failed'); });
            return r.json();
        })
        .then(function () {
            showSection('my-menu');
        })
        .catch(function (err) {
            alert('Error: ' + err.message);
            if (row) { row.style.opacity = '1'; row.style.pointerEvents = ''; }
        });
}

/* Update stat badge in parent dashboard */
(function () {
    var count = document.querySelectorAll('.menu-item-row').length;
    var el = document.getElementById('stat-menu');
    if (el) el.textContent = count;
})();
</script>
