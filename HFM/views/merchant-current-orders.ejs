<!-- merchant-current-orders.ejs — EJS fragment loaded into merchant-dashboard -->

<div class="section-card">
    <h2 class="section-title"><i class="bi bi-clock-history me-2"></i>Current Orders</h2>

    <% if (orders.length === 0) { %>
    <div class="text-center py-5" style="color:#bbb;font-family:'Poppins',sans-serif;">
        <i class="bi bi-inbox" style="font-size:2.5rem;display:block;margin-bottom:8px;"></i>
        <div style="font-size:0.88rem;">No active orders at the moment.</div>
    </div>
    <% } else { %>
    <p style="font-family:'Open Sans',sans-serif;font-size:0.85rem;color:#888;margin-bottom:20px;">
        <%= orders.length %> active order<%= orders.length !== 1 ? 's' : '' %>
    </p>

    <% orders.forEach(function(order) {
       var customerName = (order.deliveryFirstName || '') + (order.deliveryLastName ? ' ' + order.deliveryLastName.charAt(0) + '.' : '');
       customerName = customerName.trim() || ('Customer #' + order.customerId);
       var dateStr = new Date(order.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'});
    %>
    <div class="history-item">
        <div class="history-item-header" onclick="toggleHistory(this)">
            <div class="restaurant-icon"><i class="bi bi-bag"></i></div>
            <div class="flex-grow-1" style="min-width:0;">
                <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;">
                    Order #<%= order.id %> — <%= customerName %>
                </div>
                <div style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                    <%= dateStr %> &nbsp;·&nbsp; <%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3" style="flex-shrink:0;">
                <strong style="font-family:'Poppins',sans-serif;color:var(--burnt-orange-primary);">$<%= parseFloat(order.total).toFixed(2) %></strong>
                <% if (order.status === 'placed') { %>
                <span class="badge" style="background:var(--golden-yellow-secondary);color:var(--charcoal-gray-secondary);">Placed</span>
                <% } else if (order.status === 'confirmed') { %>
                <span class="badge bg-primary">Confirmed</span>
                <% } else if (order.status === 'ready') { %>
                <span class="badge bg-info text-dark">Ready</span>
                <% } %>
                <i class="bi bi-chevron-down history-chevron"></i>
            </div>
        </div>
        <div class="history-item-body">
            <div class="pt-3">
                <div style="font-family:'Poppins',sans-serif;font-size:0.8rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">Items</div>
                <ul style="font-family:'Open Sans',sans-serif;font-size:0.88rem;padding-left:18px;margin:0;">
                    <% order.items.forEach(function(item) { %>
                    <li><%= item.name %> &times; <%= item.quantity %> — $<%= parseFloat(item.price).toFixed(2) %></li>
                    <% }); %>
                </ul>
                <div class="mt-2" style="font-family:'Open Sans',sans-serif;font-size:0.82rem;color:#888;">
                    Fulfillment: <%= order.fulfillment.charAt(0).toUpperCase() + order.fulfillment.slice(1) %>
                </div>
            </div>
        </div>
    </div>
    <% }); %>
    <% } %>
</div>

<script>
function toggleHistory(header) {
    var body = header.nextElementSibling;
    body.classList.toggle('open');
    header.classList.toggle('open');
}
</script>
